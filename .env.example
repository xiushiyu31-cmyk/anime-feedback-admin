# Supabase — 在 Dashboard：Project Settings → API 复制
# 项目地址示例：https://supabase.com/dashboard/project/<project-ref>
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 仅服务端使用（Route Handler / Server Actions），永远不要放到客户端或 NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 国内可直连视觉大模型（OpenAI 兼容协议）
# 例如 SiliconFlow / DeepSeek / 其他中转：通常提供 base_url + api_key + model
AI_BASE_URL=https://你的服务域名/v1
AI_API_KEY=你的国内Key
AI_MODEL=你的视觉模型名

# 可选：xlsx 智能导入「单段」最长运行时间（毫秒），默认 55000。避免 Vercel/网关一次请求过长。
# import_parse_sessions 断点存在 Supabase 里，超时后点「继续解析」即可接着跑。
# IMPORT_SEGMENT_BUDGET_MS=55000

# 企业微信群半自动抓取脚本（安全优先版）
# 默认只预览不提交：DRY_RUN=true
# 首次运行时会打开浏览器，你手动扫码登录并手动打开目标群聊
# WECHAT_WORKBENCH_URL=https://www.xunjinet.com.cn/app/quan-msgv2/
# TARGET_GROUP_NAME=🍉文案
# FEEDBACK_API_URL=http://127.0.0.1:3001/api/feedback
# OPERATOR_NAME=青柠
# DRY_RUN=true
# REQUIRE_CONFIRM=true
# POLL_INTERVAL_MS=300000
# MAX_SCAN_MESSAGES=80
# CLASSIFY_BATCH_SIZE=10
